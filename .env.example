# Supabase project credentials.
# These two values are PUBLIC-SAFE (the anon key is meant to be shipped to the
# browser; access is protected by Row Level Security). NEVER put the service_role
# key here or anywhere in this repo.
#
# Local dev: copy to .env.local and fill in.
# Production (GitHub Pages): set as GitHub Actions repository secrets.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
